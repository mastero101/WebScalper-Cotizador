# Plantilla de Configuración de Base de Datos
# Copia este archivo como .env y completa con tus credenciales

DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306
DB_SSL=false

# Ruta al binario de Chrome/Chromium (opcional para VPS)
# Linux ejemplo: /usr/bin/chromium-browser
# Windows ejemplo: C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_PATH=
